---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../site';
---

<Layout title={`Pushup Counter — ${SITE.name}`} description="A phone-first pushup set counter with Sheets logging.">
	<h1>Pushup Counter</h1>

	<div class="card">
		<div id="locked">
			<p class="muted">
				Passcode required. This is meant to keep track of just my pushups.
			</p>
			<label class="label" for="passcode">Passcode</label>
			<input id="passcode" class="input" inputmode="numeric" autocomplete="one-time-code" />
			<div class="rowBtns authBtns">
				<button id="unlock" class="btn primary" type="button">Unlock</button>
				<button id="demo" class="btn" type="button">Try demo</button>
			</div>
			<p id="lockError" class="error" aria-live="polite"></p>
		</div>

		<div id="unlocked" hidden>
			<p id="demoNote" class="muted small" hidden>
				Demo mode. Counting works, but saving is disabled.
			</p>
			<div class="row">
				<div class="countWrap">
					<div class="countLabel muted">Set count</div>
					<div id="count" class="count">0</div>
				</div>
				<div class="rowBtns">
					<button id="inc" class="btn big primary" type="button">+1</button>
					<button id="dec" class="btn big" type="button">-1</button>
					<button id="reset" class="btn big" type="button">Reset</button>
				</div>
			</div>

			<div class="divider"></div>

			<div class="row">
				<div class="stack">
					<div class="muted">Style</div>
				</div>
				<fieldset class="segmented" aria-label="Pushup style">
					<label class="seg">
						<input type="radio" name="style" value="standard" checked />
						<span>Standard</span>
					</label>
					<label class="seg">
						<input type="radio" name="style" value="wide" />
						<span>Wide</span>
					</label>
					<label class="seg">
						<input type="radio" name="style" value="narrow" />
						<span>Narrow</span>
					</label>
				</fieldset>
			</div>

			<div class="divider"></div>

			<div class="row">
				<div class="stack">
					<div class="muted">Logging</div>
					<div id="logHelp" class="muted small">
						Adds one row to your Google Sheet when you finish a set.
					</div>
				</div>
				<button id="save" class="btn primary" type="button">Finish set &amp; save</button>
			</div>

			<p id="status" class="muted small" aria-live="polite"></p>

			<div id="sessionWrap" hidden>
				<div class="divider"></div>
				<div class="row">
					<div class="muted">Session</div>
					<div id="sessionSummary" class="muted small"></div>
				</div>
				<ul id="sessionList" class="sessionList"></ul>
			</div>

			<details class="details">
				<summary>Proximity counting (experimental)</summary>
				<p class="muted small">
					Lay your phone screen-up on the ground. As your face gets close to the camera, it counts a rep — no calibration needed.
				</p>

				<div class="divider"></div>
				<div class="row">
					<fieldset class="segmented" aria-label="Proximity mode">
						<label class="seg">
							<input type="radio" name="proxMode" value="enabled" />
							<span>Enable</span>
						</label>
						<label class="seg">
							<input type="radio" name="proxMode" value="disabled" checked />
							<span>Disable</span>
						</label>
					</fieldset>
				</div>

				<div id="proxControls" hidden>
					<div class="divider"></div>
					<div class="proxPreviewWrap">
						<canvas id="proxPreview" width="128" height="96" class="proxPreview"></canvas>
						<div class="proxMeta">
							<div class="proxRow">
								<span class="muted small">Signal</span>
								<span id="proxSignal" class="mono small muted">—</span>
							</div>
							<div class="proxRow">
								<label class="muted small" for="proxSensitivity">Sensitivity</label>
								<div class="range">
									<span class="rangeIcon" aria-hidden="true">Low</span>
									<input id="proxSensitivity" type="range" min="0.40" max="0.85" step="0.05" value="0.65" />
									<span class="rangeIcon" aria-hidden="true">High</span>
								</div>
							</div>
							<div class="proxRow">
								<label class="muted small" for="proxDebounce">Speed</label>
								<div class="range">
									<span class="rangeIcon" aria-hidden="true">Fast</span>
									<input id="proxDebounce" type="range" min="400" max="1500" step="50" value="850" />
									<span class="rangeIcon" aria-hidden="true">Slow</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</details>

			<div class="divider"></div>

			<button id="lock" class="btn" type="button">Lock</button>
		</div>
	</div>
</Layout>

<style>
	.card {
		border: 1px solid var(--border);
		border-radius: 14px;
		padding: 1rem;
		margin: 1rem 0 2rem;
	}

	.row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.segmented {
		display: inline-flex;
		border: 1px solid var(--border);
		border-radius: 12px;
		overflow: hidden;
		margin: 0;
		padding: 0;
	}

	.seg {
		display: inline-flex;
		font-size: 15px;
		cursor: pointer;
		user-select: none;
		border-right: 1px solid var(--border);
	}

	.seg:last-child {
		border-right: none;
	}

	.seg input {
		position: absolute;
		opacity: 0;
		pointer-events: none;
	}

	.seg span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.55rem 0.75rem;
		background: white;
		color: var(--muted);
	}

	.seg input:checked + span {
		background: #111827;
		color: white;
		border-right-color: #111827;
	}

	.stack {
		display: grid;
		gap: 0.25rem;
	}

	.countWrap {
		min-width: 140px;
	}

	.countLabel {
		font-size: 0.95rem;
		margin-bottom: 0.25rem;
	}

	.count {
		font-size: 64px;
		line-height: 1;
		letter-spacing: -0.03em;
		font-weight: 650;
	}

	.rowBtns {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		flex-wrap: wrap;
	}

	.authBtns {
		margin-top: 0.75rem;
	}

	.divider {
		border-top: 1px solid var(--border);
		margin: 1rem 0;
	}

	.label {
		display: block;
		margin: 0.75rem 0 0.25rem;
		color: var(--muted);
		font-size: 0.95rem;
	}

	.range {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		flex: 1;
		min-width: 0;
	}

	.range input[type='range'] {
		flex: 1;
		min-width: 0;
	}

	.rangeIcon {
		color: var(--muted);
		font-size: 13px;
		line-height: 1;
		user-select: none;
		white-space: nowrap;
	}

	.input {
		width: 100%;
		max-width: 320px;
		padding: 0.7rem 0.75rem;
		border-radius: 10px;
		border: 1px solid var(--border);
		font-size: 16px;
	}

	.btn {
		border: 1px solid var(--border);
		background: white;
		border-radius: 12px;
		padding: 0.6rem 0.85rem;
		font-size: 16px;
		cursor: pointer;
	}

	.btn.primary {
		background: #111827;
		color: white;
		border-color: #111827;
	}

	.btn.big {
		padding: 0.9rem 1.1rem;
		font-size: 18px;
	}

	.btn:active {
		transform: translateY(1px);
	}

	.btn:disabled {
		opacity: 0.55;
		cursor: not-allowed;
	}

	.btn:disabled:active {
		transform: none;
	}

	.small {
		font-size: 0.95rem;
	}

	.mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New',
			monospace;
	}

	.details {
		margin-top: 0.75rem;
	}

	.error {
		color: #b91c1c;
		margin-top: 0.5rem;
	}

	.sessionList {
		list-style: none;
		margin: 0.5rem 0 0;
		padding: 0;
		display: grid;
		gap: 0.3rem;
	}

	.sessionItem {
		display: flex;
		gap: 0.4rem;
		align-items: baseline;
		font-size: 0.9rem;
		color: var(--muted);
	}

	.proxPreviewWrap {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		margin-top: 0.5rem;
		flex-wrap: wrap;
	}

	.proxPreview {
		border-radius: 8px;
		border: 1px solid var(--border);
		background: #111;
		width: 128px;
		height: 96px;
		flex-shrink: 0;
		display: block;
	}

	.proxMeta {
		flex: 1;
		min-width: 160px;
		display: grid;
		gap: 0.6rem;
	}

	.proxRow {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.proxRow label {
		white-space: nowrap;
		min-width: 72px;
	}

	@media (max-width: 640px) {
		.count {
			font-size: 72px;
		}

		.btn.big {
			flex: 1;
			min-width: 120px;
		}
	}
</style>

<script>
	type SetEntry = { count: number; style: string; time: string };

	function getEl<T extends HTMLElement = HTMLElement>(id: string): T {
		return document.getElementById(id) as T;
	}

	const _env = import.meta.env as Record<string, string | undefined>;
	const WEBHOOK_URL = _env['PUBLIC_PUSHUP_WEBHOOK_URL'] ?? '';
	const API_URL = '/api/pushups';
	const EXPECTED_PASSCODE = _env['PUBLIC_PUSHUP_PASSCODE'] ?? '1021';

	const STORAGE_KEY = 'pushupCounterUnlocked';
	const PASSCODE_KEY = 'pushupCounterPasscode';
	const STYLE_KEY = 'pushupCounterStyle';
	const COUNT_KEY = 'pushupCounterCurrentCount';

	const el = {
		locked: getEl('locked'),
		unlocked: getEl('unlocked'),
		passcode: getEl<HTMLInputElement>('passcode'),
		unlock: getEl('unlock'),
		demo: getEl('demo'),
		lock: getEl('lock'),
		lockError: getEl('lockError'),
		demoNote: getEl('demoNote'),
		count: getEl('count'),
		inc: getEl('inc'),
		dec: getEl('dec'),
		reset: getEl('reset'),
		save: getEl<HTMLButtonElement>('save'),
		status: getEl('status'),
		proxSignal: getEl('proxSignal'),
		proxControls: getEl('proxControls'),
		proxPreview: getEl<HTMLCanvasElement>('proxPreview'),
		proxSensitivity: getEl<HTMLInputElement>('proxSensitivity'),
		proxDebounce: getEl<HTMLInputElement>('proxDebounce'),
		sessionWrap: getEl('sessionWrap'),
		sessionSummary: getEl('sessionSummary'),
		sessionList: getEl('sessionList'),
	};

	function setStatus(text: string): void {
		el.status.textContent = text;
	}

	function setError(text: string): void {
		el.lockError.textContent = text;
	}

	function vibrate(ms = 30): void {
		navigator.vibrate?.(ms);
	}

	function isUnlocked(): boolean {
		return localStorage.getItem(STORAGE_KEY) === '1';
	}

	function getPasscode(): string {
		return String(el.passcode.value || localStorage.getItem(PASSCODE_KEY) || '').trim();
	}

	function getStyle(): string {
		return String(
			(document.querySelector('input[name="style"]:checked') as HTMLInputElement | null)?.value ||
				'standard',
		);
	}

	function setStyle(value: string): void {
		const radio = document.querySelector(
			`input[name="style"][value="${value}"]`,
		) as HTMLInputElement | null;
		if (radio) radio.checked = true;
	}

	function showUnlocked(): void {
		el.locked.hidden = true;
		el.unlocked.hidden = false;
	}

	function showLocked(): void {
		el.unlocked.hidden = true;
		el.locked.hidden = false;
		el.passcode.value = '';
	}

	let demoMode = false;
	let sessionPasscode = '';

	function setDemoMode(next: boolean): void {
		demoMode = Boolean(next);
		el.demoNote.hidden = !demoMode;
		el.save.disabled = demoMode;
	}

	function lock(): void {
		disableProximity({ quiet: true });
		setDemoMode(false);
		sessionPasscode = '';
		localStorage.removeItem(STORAGE_KEY);
		localStorage.removeItem(PASSCODE_KEY);
		el.passcode.value = '';
		showLocked();
		setError('');
		setStatus('');
	}

	function unlock(): void {
		const entered = getPasscode();
		setError('');
		setStatus('');
		if (entered !== EXPECTED_PASSCODE) {
			setError('Incorrect passcode.');
			return;
		}
		setDemoMode(false);
		localStorage.setItem(STORAGE_KEY, '1');
		localStorage.setItem(PASSCODE_KEY, entered);
		sessionPasscode = entered;
		el.passcode.value = '';
		showUnlocked();
		setError('');
	}

	function enterDemo(): void {
		setDemoMode(true);
		showUnlocked();
		setError('');
		setStatus('Demo mode. Saving is disabled.');
	}

	let count = 0;

	function renderCount(): void {
		el.count.textContent = String(count);
		localStorage.setItem(COUNT_KEY, String(count));
	}

	// --- Session log ---

	let sessionSets: SetEntry[] = [];

	function logSet(entry: SetEntry): void {
		sessionSets.push(entry);
		renderSession();
	}

	function renderSession(): void {
		if (sessionSets.length === 0) {
			el.sessionWrap.hidden = true;
			return;
		}
		el.sessionWrap.hidden = false;
		const totalReps = sessionSets.reduce((s, e) => s + e.count, 0);
		const sets = sessionSets.length;
		el.sessionSummary.textContent = `${sets} set${sets === 1 ? '' : 's'} · ${totalReps} total reps`;
		el.sessionList.innerHTML = [...sessionSets]
			.reverse()
			.map(
				(e) =>
					`<li class="sessionItem"><strong>${e.count}</strong> reps · ${e.style} · <span class="muted">${e.time}</span></li>`,
			)
			.join('');
	}

	// --- Save to Google Sheet ---

	// Image beacon used only in dev (CF functions don't run in Astro dev server).
	function sendGetBeacon(url: string): Promise<void> {
		return new Promise((resolve) => {
			const img = new Image();
			const done = (): void => resolve();
			const timeout = setTimeout(done, 2500);
			img.onload = () => {
				clearTimeout(timeout);
				done();
			};
			img.onerror = () => {
				clearTimeout(timeout);
				done();
			};
			img.src = url;
		});
	}

	async function saveSet(): Promise<void> {
		if (demoMode) {
			setStatus('Demo mode. Saving is disabled.');
			return;
		}
		if (count <= 0) {
			setStatus('Nothing to save yet.');
			return;
		}
		if (!isUnlocked()) {
			setStatus('Unlock to enable saving.');
			return;
		}

		const now = new Date();
		const recordedAt = now.toISOString();
		const recordedDate = new Intl.DateTimeFormat('en-US', {
			month: 'short',
			day: '2-digit',
			year: 'numeric',
		}).format(now);
		const recordedTime = new Intl.DateTimeFormat('en-US', {
			hour: 'numeric',
			minute: '2-digit',
		}).format(now);

		const style = getStyle();
		const savedCount = count;

		setStatus('Saving…');
		el.save.disabled = true;

		try {
			const payload: Record<string, string> = {
				date: recordedDate,
				time: recordedTime,
				count: String(savedCount),
				style,
				recordedAt,
			};

			if (import.meta.env.DEV) {
				// Dev: CF function not available, call webhook directly via image beacon.
				if (!WEBHOOK_URL) {
					setStatus('No webhook configured (dev mode).');
					return;
				}
				const url = new URL(WEBHOOK_URL);
				Object.entries(payload).forEach(([k, v]) => url.searchParams.set(k, v));
				url.searchParams.set('passcode', sessionPasscode || getPasscode());
				url.searchParams.set('v', String(Date.now()));
				await sendGetBeacon(url.toString());
				logSet({ count: savedCount, style, time: recordedTime });
				setStatus('Saved (dev: sent to webhook).');
			} else {
				const url = new URL(API_URL, window.location.origin);
				Object.entries(payload).forEach(([k, v]) => url.searchParams.set(k, v));
				url.searchParams.set('v', String(Date.now()));

				const res = await fetch(url.toString());
				if (!res.ok) {
					const data = (await res.json().catch(() => ({}))) as { error?: string };
					setStatus(`Save failed (${data.error ?? res.status}). Tap again to retry.`);
					return;
				}
				logSet({ count: savedCount, style, time: recordedTime });
				setStatus('Saved ✓');
			}

			count = 0;
			renderCount();
		} catch {
			setStatus('Save failed (network error). Tap again to retry.');
		} finally {
			el.save.disabled = false;
		}
	}

	// --- Proximity (camera) counting with adaptive baseline ---

	const BASELINE_ALPHA = 0.02;

	let proxEnabled = false;
	let proxNear = false;
	let proxLastRepAt = 0;
	let baselineLuma: number | null = null;
	let proxStream: MediaStream | null = null;
	let proxVideo: HTMLVideoElement | null = null;
	let proxCanvas: HTMLCanvasElement | null = null;
	let proxCtx: CanvasRenderingContext2D | null = null;
	let proxPreviewCtx: CanvasRenderingContext2D | null = null;
	let proxRaf = 0;

	function setProxMode(mode: 'enabled' | 'disabled'): void {
		const radio = document.querySelector(
			`input[name="proxMode"][value="${mode}"]`,
		) as HTMLInputElement | null;
		if (radio) radio.checked = true;
	}

	function proxSensitivity(): number {
		return Number(el.proxSensitivity.value);
	}

	function proxDebounceMs(): number {
		return Number(el.proxDebounce.value);
	}

	function proxUpdateLoop(): void {
		if (!proxEnabled) return;
		if (!proxVideo || proxVideo.readyState < 2) {
			proxRaf = requestAnimationFrame(proxUpdateLoop);
			return;
		}

		const vw = proxVideo.videoWidth || 0;
		const vh = proxVideo.videoHeight || 0;
		if (!vw || !vh || !proxCtx || !proxCanvas) {
			proxRaf = requestAnimationFrame(proxUpdateLoop);
			return;
		}

		// Center-crop to 64x64 for luma calculation.
		const size = 64;
		const sx = Math.max(0, Math.floor(vw / 2 - size));
		const sy = Math.max(0, Math.floor(vh / 2 - size));
		const sw = Math.min(vw, size * 2);
		const sh = Math.min(vh, size * 2);

		proxCtx.drawImage(proxVideo, sx, sy, sw, sh, 0, 0, size, size);
		const data = proxCtx.getImageData(0, 0, size, size).data;

		let sum = 0;
		for (let i = 0; i < data.length; i += 4) {
			sum += 0.2126 * data[i] + 0.7152 * data[i + 1] + 0.0722 * data[i + 2];
		}
		const luma = sum / (data.length / 4);

		// Initialize or update the adaptive baseline.
		if (baselineLuma === null) {
			baselineLuma = luma;
		} else if (!proxNear) {
			// Only update baseline when face is away so it doesn't drift toward "blocked".
			baselineLuma = (1 - BASELINE_ALPHA) * baselineLuma + BASELINE_ALPHA * luma;
		}

		const ratio = luma / Math.max(baselineLuma, 1);
		const sensitivity = proxSensitivity();
		const hysteresis = 0.12;
		const nearNow = ratio < sensitivity;
		const farNow = ratio > sensitivity + hysteresis;

		if (!proxNear && nearNow) {
			const now = Date.now();
			if (now - proxLastRepAt > proxDebounceMs()) {
				proxLastRepAt = now;
				count += 1;
				renderCount();
				vibrate(40);
			}
			proxNear = true;
		} else if (proxNear && farNow) {
			proxNear = false;
		}

		// Draw preview: full video frame with a near/far color tint.
		if (proxPreviewCtx) {
			const pw = el.proxPreview.width;
			const ph = el.proxPreview.height;
			proxPreviewCtx.drawImage(proxVideo, 0, 0, pw, ph);
			proxPreviewCtx.fillStyle = proxNear
				? 'rgba(220, 38, 38, 0.35)'
				: 'rgba(34, 197, 94, 0.15)';
			proxPreviewCtx.fillRect(0, 0, pw, ph);
		}

		const blocked = Math.round((1 - ratio) * 100);
		el.proxSignal.textContent = `${blocked}% blocked · ${proxNear ? 'near' : 'far'}`;

		proxRaf = requestAnimationFrame(proxUpdateLoop);
	}

	async function enableProximity(): Promise<void> {
		if (proxEnabled) return;
		if (!navigator.mediaDevices?.getUserMedia) {
			setStatus('Camera not supported in this browser.');
			return;
		}

		try {
			proxStream = await navigator.mediaDevices.getUserMedia({
				video: { facingMode: 'user' },
				audio: false,
			});
		} catch {
			setStatus('Camera permission denied.');
			setProxMode('disabled');
			return;
		}

		proxVideo = document.createElement('video');
		proxVideo.playsInline = true;
		proxVideo.muted = true;
		proxVideo.srcObject = proxStream;
		await proxVideo.play().catch(() => {});

		proxCanvas = document.createElement('canvas');
		proxCanvas.width = 64;
		proxCanvas.height = 64;
		proxCtx = proxCanvas.getContext('2d', { willReadFrequently: true });
		if (!proxCtx) {
			setStatus('Camera processing not available.');
			disableProximity({ quiet: true });
			return;
		}

		proxPreviewCtx = el.proxPreview.getContext('2d');

		proxEnabled = true;
		proxNear = false;
		proxLastRepAt = 0;
		baselineLuma = null;
		el.proxControls.hidden = false;
		el.proxSignal.textContent = '…';
		setProxMode('enabled');
		setStatus('Proximity enabled. Do a test rep to calibrate.');
		proxUpdateLoop();
	}

	function disableProximity({ quiet } = { quiet: false }): void {
		if (!proxEnabled && !proxStream) return;
		proxEnabled = false;
		proxNear = false;
		proxLastRepAt = 0;
		baselineLuma = null;

		if (proxRaf) cancelAnimationFrame(proxRaf);
		proxRaf = 0;

		if (proxStream) {
			for (const t of proxStream.getTracks()) t.stop();
		}
		proxStream = null;
		proxVideo = null;
		proxCanvas = null;
		proxCtx = null;
		proxPreviewCtx = null;

		el.proxControls.hidden = true;
		el.proxSignal.textContent = '—';
		setProxMode('disabled');
		if (!quiet) setStatus('Proximity disabled.');
	}

	// --- Wire up UI ---

	el.inc.addEventListener('click', () => {
		count += 1;
		renderCount();
		vibrate(30);
	});

	el.dec.addEventListener('click', () => {
		count = Math.max(0, count - 1);
		renderCount();
	});

	el.reset.addEventListener('click', () => {
		count = 0;
		renderCount();
		setStatus('');
	});

	el.unlock.addEventListener('click', unlock);
	el.demo.addEventListener('click', enterDemo);
	el.lock.addEventListener('click', lock);
	el.save.addEventListener('click', saveSet);

	document.querySelectorAll<HTMLInputElement>('input[name="proxMode"]').forEach((radio) => {
		radio.addEventListener('change', () => {
			const mode = String(
				(document.querySelector('input[name="proxMode"]:checked') as HTMLInputElement | null)
					?.value || 'disabled',
			);
			if (mode === 'enabled') enableProximity();
			else disableProximity();
		});
	});

	el.passcode.addEventListener('keydown', (e: KeyboardEvent) => {
		if (e.key === 'Enter') unlock();
	});

	document.querySelectorAll<HTMLInputElement>('input[name="style"]').forEach((radio) => {
		radio.addEventListener('change', () => localStorage.setItem(STYLE_KEY, getStyle()));
	});

	// --- Initial state ---

	el.passcode.value = '';
	setStyle(localStorage.getItem(STYLE_KEY) || 'standard');
	setProxMode('disabled');
	setDemoMode(false);

	const savedCount = parseInt(localStorage.getItem(COUNT_KEY) ?? '0', 10);
	count = isNaN(savedCount) || savedCount < 0 ? 0 : savedCount;
	el.count.textContent = String(count);

	if (isUnlocked()) showUnlocked();
</script>
